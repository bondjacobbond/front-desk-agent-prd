      "data": {
        "name": "Tool: Get Facility Schedule",
        "method": "POST",
        "url": "https://YOUR_TOOLS_HOST/bland/get-facility-schedule",
        "body": "{\"facilityId\":42,\"callerMessage\":\"{{lastUserMessage}}\"}",
        "prompt": "Call the schedule tool to answer time and availability questions.",
        "responseData": [
          {
            "data": "status",
            "name": "schedule_status",
            "context": ""
          },
          {
            "data": "assistant_response",
            "name": "tool_result",
            "context": ""
          }
        ],
        "responsePathways": [
