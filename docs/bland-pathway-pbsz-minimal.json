      "type": "Default",
      "position": {
        "x": -420,
        "y": 20
      },
      "data": {
        "name": "Route Intent",
        "prompt": "Classify the caller intent and route to the best pathway. Keep response short and friendly. Use schedule tools for timing/availability, programs tool for catalog/pricing, transfer for bookings/complex cases.",
        "modelOptions": {
          "modelType": "smart",
          "temperature": 0.2,
          "skipUserResponse": false,
          "block_interruptions": false
        },
        "pathwayExamples": [
          {
            "Chosen Pathway": "Caller asks about times, what's on today, or availability",
            "Conversation History": "What time is public skate tonight?"
          },
          {
            "Chosen Pathway": "Caller asks about classes, pricing, age range, or registration",
            "Conversation History": "How much is Learn to Skate and when does it start?"
          },
          {
            "Chosen Pathway": "Caller asks for exact dates/times for a specific program session",
            "Conversation History": "For program 123 session 456, what exact event dates are left?"
          },
          {
            "Chosen Pathway": "Caller wants booking/sign-up or asks for a human",
            "Conversation History": "Can you book a birthday party for Saturday?"
          },
          {
            "Chosen Pathway": "Caller says goodbye",
            "Conversation History": "Thanks, bye"
          }
        ]
      }
    },
