# Vapi Configuration
REACT_APP_VAPI_PUBLIC_KEY=your_public_key_here
REACT_APP_VAPI_ASSISTANT_ID=your_assistant_id_here

# Optional: Vapi Server URL (defaults to production)
# REACT_APP_VAPI_BASE_URL=https://api.vapi.ai

# Bond API (for Vapi tool-calls webhook at /api/vapi/tool-calls)
BOND_API_KEY=your_bond_api_key_here

# Feature flags
# Set to "true" to show the Integration Reference appendix (hidden in prod by default)
NEXT_PUBLIC_SHOW_INTEGRATION_DOCS=false
